{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"options": {
				"cwd": "${workspaceFolder}/lib"
			},
			"command": "build",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "rust: cargo build"
		},
		{
			"type": "shell",
			"label": "build: rasberry_pico_w (thumbv6m)",
			"command": "cargo",
			"args": [
				"build",
				"--target",
				"thumbv6m-none-eabi"
			],
			"options": {
				"cwd": "${workspaceFolder}/demos/rasberry_pico_w"
			},
			"problemMatcher": [
				"$rustc"
			],
			"group": "build"
		}
	]
}
