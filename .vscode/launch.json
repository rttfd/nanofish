{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug RP2040 (probe-rs)",
      "type": "probe-rs-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}/demos/rasberry_pico_w",
      "chip": "RP2040",
      "wireProtocol": "Swd",
      "flashingConfig": {
        "flashingEnabled": true,
        "haltAfterReset": true
      },
      "coreConfigs": [
        {
          "coreIndex": 0,
          "programBinary": "target/thumbv6m-none-eabi/debug/rasberry_pico_w",
          "rttEnabled": true,
          "rttChannelFormats": [
            {
              "channelNumber": 0,
              "dataFormat": "Defmt",
              "showTimestamps": true
            }
          ],
          "catchHardfault": true
        }
      ],
      "preLaunchTask": "build: rasberry_pico_w (thumbv6m)"
    }
  ]
}
